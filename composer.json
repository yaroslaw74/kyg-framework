    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-intl": "*",
        "symfony/polyfill-intl-grapheme": "*",
        "symfony/polyfill-intl-icu": "*",
        "symfony/polyfill-intl-idn": "*",
        "symfony/polyfill-intl-normalizer": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Additions\\": "public/additions/",
            "App\\Modules\\": "modules/"
        },
        "classmap": [
            "config/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "liborm85/composer-vendor-cleaner": true,
            "neronmoon/scriptsdev": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "symfony/thanks": true
        },
        "apcu-autoloader": true,
        "bump-after-update": true,
        "dev-files": {
            "no-dev-only": true
        },
        "optimize-autoloader": true,
        "process-timeout": 3000,
        "sort-packages": true
    },
    "extra": {
        "copy-file": {
            "modules/Config/Resources/data/config/": "var/config/",
            "modules/Config/Resources/data/theme/": "public/theme/"
        },
        "dev-files": {
            "*/*": [
                ".git/",
                ".github/",
                ".phive/",
                "docs/",
                "test/",
                "tests/",
                "*.md",
                "CHANGELOG",
                "CREDITS",
                "LICENCE",
                "LICENSE",
                "LICENSE.*",
                "NOTICE",
                "README",
                "README.*",
                "Makefile",
                ".deepsource.toml",
                ".gitattributes",
                ".editorconfig",
                ".gitignore",
                ".gitmodules",
                ".phpstorm.meta.php",
                ".php_cs.php",
                ".php_cs.dist",
                ".php-cs-fixer.php",
                ".php-cs-fixer.dist.php",
                ".prettierrc",
                ".roave-backward-compatibility-check.xml",
                ".travis.yml",
                ".valgrindrc",
                "biome.json",
                "composer.json",
                "composer.lock",
                "composer-require-check.json",
                "phpbench.json",
                "phpcs.xml",
                "phpdoc.dist.xml",
                "phpstan.dist.neon",
                "phpstan.neon",
                "phpstan.neon.dist",
                "phpunit.xml",
                "phpunit.dist.xml",
                "phpunit.xml.dist",
                "phpunit-deprecation-baseline.xml",
                "phpunit-rector.xml.dist",
                "phpunit11.dist.xml",
                "phpstan-baseline.neon",
                "psalm.xml",
                "psalm-baseline.xml"
            ]
        },
        "mkdir": {
            "migrations": "0644",
            "public/additions": "0777",
            "public/storage": "0777",
            "public/storage/Documents": "0777",
            "public/storage/Downloads": "0777",
            "public/storage/Images": "0777",
            "public/storage/Music": "0777",
            "public/storage/Other": "0777",
            "public/storage/Videos": "0777",
            "public/translations": "0777",
            "public/uploads": "0777"
        },
        "scripts-dev": {
            "post-install-cmd": [
                "@php bin/console biomejs:download"
            ],
            "post-update-cmd": [
                "@php bin/console lint:twig templates/ public/additions/ modules/ --show-deprecations",
                "vendor/bin/twig-cs-fixer fix",
                "bin/biome lint --write assets modules public/additions",
                "bin/biome check --write assets modules public/additions",
                "bin/biome format --write assets modules public/additions",
                "vendor/bin/phpstan analyse --error-format friendly",
                "vendor/bin/psalm --alter --issues=MismatchingDocblockParamType,UnusedMethod --dry-run",
                "vendor/bin/php-cs-fixer fix",
                "@php bin/console doctrine:diagram:er",
                "@php bin/console doctrine:diagram:class"
            ]
        },
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "Balrok\\ComposerMkdir\\ScriptHandler::mkdirs",
            "SlowProg\\CopyFile\\ScriptHandler::copy",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "auto-scripts": {
            "requirements-checker": "script",
            "cache:clear": "symfony-cmd",
            "cache:warmup": "symfony-cmd",
            "ckeditor:install --clear=drop --release=full": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "importmap:update": "symfony-cmd"
        }
    }
}
