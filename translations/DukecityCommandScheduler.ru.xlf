        <source>detail.command</source>
        <target>Командование</target>
      </trans-unit>
      <trans-unit id="204">
        <source>detail.arguments</source>
        <target>Аргументы</target>
      </trans-unit>
      <trans-unit id="205">
        <source>detail.cronExpression</source>
        <target>Выражение Cron</target>
      </trans-unit>
      <trans-unit id="206">
        <source>detail.logFile</source>
        <target>Выходной файл</target>
      </trans-unit>
      <trans-unit id="207">
        <source>detail.priority</source>
        <target>Приоритет</target>
      </trans-unit>
