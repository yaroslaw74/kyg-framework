        <source>detail.locked</source>
        <target>Заблокировано</target>
      </trans-unit>
      <trans-unit id="215">
        <source>detail.nextRun</source>
        <target>Следующий запуск</target>
      </trans-unit>
      <trans-unit id="216">
        <source>detail.pingBackUrl</source>
        <target>PingBackUrl</target>
      </trans-unit>
      <trans-unit id="217">
        <source>detail.pingBackFailedUrl</source>
        <target>PingBackFailedUrl</target>
      </trans-unit>
      <trans-unit id="218">
        <source>detail.notes</source>
        <target>примечания</target>
      </trans-unit>
