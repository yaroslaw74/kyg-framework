      <trans-unit id="100">
        <source>action.delete</source>
        <target>Удалить</target>
      </trans-unit>
      <trans-unit id="101">
        <source>action.execute</source>
        <target>Выполнить</target>
      </trans-unit>
      <trans-unit id="102">
        <source>action.edit</source>
        <target>Редактировать</target>
      </trans-unit>
      <trans-unit id="103">
        <source>action.new</source>
        <target>Новое расписание</target>
      </trans-unit>
      <trans-unit id="104">
        <source>confirm.delete</source>
        <target>Удалить эту задачу навсегда?</target>
      </trans-unit>
      <trans-unit id="105">
        <source>confirm.execute</source>
        <target>Принудительное выполнение этой задачи?</target>
      </trans-unit>
      <trans-unit id="106">
        <source>action.unlock</source>
        <target>Разблокировать задачу</target>
      </trans-unit>
      <trans-unit id="107">
        <source>confirm.unlock</source>
        <target>Возможно, задача уже выполняется. Вы уверены, что хотите её разблокировать?</target>
      </trans-unit>
      <trans-unit id="108">
        <source>action.search</source>
        <target>Поиск</target>
      </trans-unit>
      <trans-unit id="109">
        <source>action.list</source>
        <target>Вернуться к списку</target>
      </trans-unit>
      <trans-unit id="110">
        <source>action.cancel</source>
        <target>Отмена</target>
      </trans-unit>
