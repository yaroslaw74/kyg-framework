        <source>confirm.disable</source>
        <target>Возможно, задача уже выполняется. Вы уверены, что хотите её отключить?</target>
      </trans-unit>
      <trans-unit id="112">
        <source>action.disable</source>
        <target>Отключить задачу</target>
      </trans-unit>

