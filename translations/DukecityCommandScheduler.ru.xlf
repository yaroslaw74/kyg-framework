      <trans-unit id="300">
        <source>flash.success</source>
        <target>Планирование успешно сохранено.</target>
      </trans-unit>
      <trans-unit id="301">
        <source>flash.deleted</source>
        <target>Запись в расписании успешно удалена.</target>
      </trans-unit>
      <trans-unit id="302">
        <source>flash.execute</source>
        <target>Команда "%name%" будет выполнена в течение следующего "scheduler:execute".</target>
      </trans-unit>
      <trans-unit id="303">
        <source>flash.unlocked</source>
        <target>Процесс планирования успешно разблокирован.</target>
      </trans-unit>

      <!-- admin label -->
      <trans-unit id="400">
        <source>label.null</source>
        <target>Null</target>
      </trans-unit>
      <trans-unit id="401">
        <source>label.true</source>
        <target>True</target>
      </trans-unit>
      <trans-unit id="402">
        <source>label.false</source>
        <target>False</target>
      </trans-unit>
