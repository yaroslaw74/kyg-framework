        <source>detail.executeImmediately.help</source>
        <target>Пожалуйста, запустите cron-задание один раз, чтобы убедиться в его корректном выполнении.</target>
      </trans-unit>
      <trans-unit id="221">
        <source>detail.card.header.title</source>
        <target>Команда</target>
      </trans-unit>

